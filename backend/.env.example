# Local development (SQLite — default)
DATABASE_PATH=../database/database.sqlite

# Production PostgreSQL (when set, takes precedence over DATABASE_PATH)
# DATABASE_URL=postgres://hrm:password@localhost:5432/hrm

HOST=0.0.0.0
PORT=3001
BIOMETRIC_PORT=7788
BIO_PARK_TCP_PORT=5010

# Required in release builds (min 32 chars)
JWT_SECRET=change-me-at-least-32-random-characters-long

# Dev only — do not use in production
# ALLOW_INSECURE_SECRETS=1

# Comma-separated CORS origins (production HTTPS URLs)
# CORS_ORIGINS=https://app.example.com,https://platform.example.com

# Platform admin (seeded on first start if password >= 12 chars)
# PLATFORM_ADMIN_EMAIL=platform@hrm.local
# PLATFORM_ADMIN_PASSWORD=ChangeMe-Platform-2026!

# Signup OTP (email + WhatsApp before public registration completes)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=no-reply@example.com
# MSG91_AUTH_KEY=
# MSG91_INTEGRATED_NUMBER=
# MSG91_TEMPLATE_NAME=brcddyotp
# MSG91_TEMPLATE_NAMESPACE=
# MSG91_TEMPLATE_LANGUAGE=en
# MSG91_TEMPLATE_BODY_PARAM_KEY=body_1
# MSG91_TEMPLATE_BUTTON_KEY=button_1
# SIGNUP_OTP_DEBUG=1
# SIGNUP_OTP_BYPASS=1

# Optional
# BIOMETRIC_STRICT_IP=1
# ALLOW_PUBLIC_SIGNUP=0
# STORAGE_PATH=../storage
