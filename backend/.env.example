# PostgreSQL (required — local and production)
# Start local DB: docker compose up -d  (see repo root docker-compose.yml)
DATABASE_URL=postgres://hrm:hrm@127.0.0.1:5433/hrm

HOST=0.0.0.0
PORT=3001
BIOMETRIC_PORT=7788
BIO_PARK_TCP_PORT=5010

# Required in release builds (min 32 chars)
JWT_SECRET=change-me-at-least-32-random-characters-long

# Dev only — do not use in production
# ALLOW_INSECURE_SECRETS=1

# Comma-separated CORS origins (production HTTPS URLs)
# CORS_ORIGINS=https://app.example.com,https://platform.example.com

# Platform admin (seeded on first start if password >= 12 chars)
# PLATFORM_ADMIN_EMAIL=platform@hrm.local
# PLATFORM_ADMIN_PASSWORD=ChangeMe-Platform-2026!

# Signup / welcome / payslip email — used when org App Settings has no SMTP
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_ENCRYPTION=tls
# SMTP_FROM=HRM DADDY <noreply@example.com>
# SMTP_FROM_NAME=HRM DADDY
# Optional QA redirect (all mail goes here; subject prefixed with original To)
# MAIL_OVERRIDE=test@example.com
# TENANT_APP_URL=http://localhost:5174
# MSG91_AUTH_KEY=
# MSG91_INTEGRATED_NUMBER=
# MSG91_TEMPLATE_NAME=brcddyotp
# MSG91_TEMPLATE_NAMESPACE=
# MSG91_TEMPLATE_LANGUAGE=en
# MSG91_TEMPLATE_BODY_PARAM_KEY=body_1
# MSG91_TEMPLATE_BUTTON_KEY=button_1
# SIGNUP_OTP_DEBUG=1
# SIGNUP_OTP_BYPASS=1

# Optional
# BIOMETRIC_STRICT_IP=1
# ALLOW_PUBLIC_SIGNUP=0
# STORAGE_PATH=../storage

# AWS S3 (when AWS_S3_BUCKET is set, uploads dual-write local + S3; reads fall back to S3)
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=raintech-daddy
# AWS_S3_PREFIX=hrm
# AWS_S3_FORCE_PATH_STYLE=false
# AWS_S3_ENDPOINT=
# CLOUDFRONT_URL=
