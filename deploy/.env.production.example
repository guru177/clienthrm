# Copy to deploy/.env on the server (or let scripts/deploy-production.ps1 generate it).
TENANT_DOMAIN=hrm.example.com
PLATFORM_DOMAIN=platform.example.com
API_DOMAIN=api.example.com
ACME_EMAIL=admin@example.com

POSTGRES_DB=hrm
POSTGRES_USER=hrm
POSTGRES_PASSWORD=change-me

JWT_SECRET=change-me-long-random-string
PLATFORM_ADMIN_EMAIL=admin@example.com
PLATFORM_ADMIN_PASSWORD=change-me
PLATFORM_ADMIN_NAME=Platform Admin

# Pre-built Rust API image from GitHub Actions (see .github/workflows/build-backend-image.yml)
BACKEND_IMAGE=ghcr.io/guru177/hrm-rust-backend:latest

# Only if the GHCR package is private — create a read-only PAT with read:packages
# GHCR_USERNAME=your-github-username
# GHCR_TOKEN=ghp_xxxxxxxx

BIOMETRIC_STRICT_IP=1
CORS_ORIGINS=https://hrm.example.com,https://platform.example.com,https://hrm.hoteldaddy.in,https://platform.hoteldaddy.in
TRUST_PROXY=1
ALLOW_PUBLIC_SIGNUP=1
TENANT_APP_URL=https://hrm.example.com

VITE_TENANT_APP_URL=https://hrm.example.com
VITE_PLATFORM_APP_URL=https://platform.example.com

SIGNUP_OTP_DEBUG=0
SIGNUP_OTP_BYPASS=0
RUST_LOG=info
