# Copy to deploy/.env and fill in before: docker compose -f deploy/docker-compose.production.yml up -d

# ── Domains (must point to your server IP in DNS) ─────────────
TENANT_DOMAIN=app.yourcompany.com
PLATFORM_DOMAIN=platform.yourcompany.com
API_DOMAIN=api.yourcompany.com
ACME_EMAIL=admin@yourcompany.com

# ── PostgreSQL (multi-tenant production DB) ───────────────────
POSTGRES_DB=hrm
POSTGRES_USER=hrm
POSTGRES_PASSWORD=change-me-strong-postgres-password

# ── Backend secrets (required in production) ──────────────────
JWT_SECRET=change-me-at-least-32-random-characters-long
PLATFORM_ADMIN_EMAIL=platform@yourcompany.com
PLATFORM_ADMIN_PASSWORD=change-me-platform-admin-12chars
PLATFORM_ADMIN_NAME=Platform Admin

# Optional: strict biometric device IP matching
BIOMETRIC_STRICT_IP=1

# CORS — must match your HTTPS app URLs (comma-separated, no spaces)
CORS_ORIGINS=https://app.yourcompany.com,https://platform.yourcompany.com

# Behind Caddy/nginx — required for correct client IP rate limiting
TRUST_PROXY=1

# Razorpay (webhook secret required when RAZORPAY_KEY_ID is set)
RAZORPAY_WEBHOOK_SECRET=change-me-razorpay-webhook-secret

# Optional: Redis for distributed rate limiting across replicas
# REDIS_URL=redis://redis:6379

# PostgreSQL row-level security (auto-enabled in release when DATABASE_URL is set)
# DISABLE_PG_RLS=1

# API rate limit per IP per minute (default 300 in production)
# HRM_API_RATE_MAX=300

# Frontend build-time URLs (used during docker build)
VITE_TENANT_APP_URL=https://app.yourcompany.com
VITE_PLATFORM_APP_URL=https://platform.yourcompany.com

# Do NOT set ALLOW_INSECURE_SECRETS in production
