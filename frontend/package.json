{
    "name": "raintech-hrm",
    "version": "1.0.0",
    "description": "HR Daddy — tenant desktop and web client",
    "author": "Raintech Software",
    "private": true,
    "type": "module",
    "main": "electron/main.cjs",
    "scripts": {
        "dev": "vite",
        "dev:tunnel": "vite --mode tunnel",
        "build": "vite build",
        "preview": "vite preview",
        "electron:dev": "concurrently -k \"npm run dev\" \"wait-on tcp:5174 && electron .\"",
        "electron:build": "node scripts/clean-electron-packaging.mjs && node scripts/ensure-production-api.mjs && node scripts/generate-installer-assets.mjs && npm run build && electron-builder",
        "electron:build:local": "node scripts/clean-electron-packaging.mjs && node scripts/ensure-local-api.mjs && node scripts/generate-installer-assets.mjs && npm run build && electron-builder",
        "electron:build:hoteldaddy": "node scripts/clean-electron-packaging.mjs && node scripts/ensure-hoteldaddy-api.mjs && node scripts/generate-installer-assets.mjs && npm run build && electron-builder --config electron-builder.hoteldaddy.json",
        "electron:build:tunnel": "node scripts/clean-electron-packaging.mjs && node scripts/ensure-tunnel-api.mjs && node scripts/generate-installer-assets.mjs && npm run build && electron-builder",
        "electron:assets": "node scripts/generate-installer-assets.mjs",
        "electron:publish-local": "npm run electron:build && node scripts/publish-desktop-update.cjs",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "lint": "tsc --noEmit -p tsconfig.json"
    },
    "build": {
        "appId": "com.raintech.hrm",
        "productName": "HR Daddy",
        "copyright": "Copyright © Raintech Software",
        "artifactName": "HR-Daddy-Setup-${version}.${ext}",
        "asar": true,
        "npmRebuild": false,
        "removePackageScripts": true,
        "publish": [
            {
                "provider": "generic",
                "url": "http://127.0.0.1:3001/api/public/desktop/updates"
            }
        ],
        "directories": {
            "output": "release",
            "buildResources": "build"
        },
        "files": [
            {
                "from": ".",
                "filter": [
                    "dist/**/*",
                    "!dist/**/*.map",
                    "electron/**/*",
                    "!electron/branding/**",
                    "!electron/**/*.example",
                    "package.json"
                ]
            }
        ],
        "extraResources": [
            {
                "from": "electron/branding",
                "to": "branding",
                "filter": [
                    "**/*"
                ]
            }
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "build/icon.ico",
            "legalTrademarks": "HR Daddy is a trademark of Raintech Software"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowElevation": true,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": "build/icon.ico",
            "uninstallerIcon": "build/icon.ico",
            "installerHeader": "build/installerHeader.bmp",
            "installerSidebar": "build/installerSidebar.bmp",
            "uninstallerSidebar": "build/uninstallerSidebar.bmp",
            "license": "build/license.txt",
            "include": "build/installer.nsh",
            "installerLanguages": [
                "en_US"
            ],
            "displayLanguageSelector": false,
            "createDesktopShortcut": "always",
            "createStartMenuShortcut": true,
            "shortcutName": "HR Daddy",
            "menuCategory": "HR Daddy",
            "runAfterFinish": true,
            "deleteAppDataOnUninstall": false,
            "guid": "a7c4e8f2-9b1d-4e6a-bc3d-0187a3b4c5d6"
        },
        "mac": {
            "target": "dmg",
            "icon": "build/icon.ico",
            "category": "public.app-category.business"
        },
        "linux": {
            "target": [
                "AppImage"
            ],
            "icon": "build/icon.ico",
            "category": "Office"
        }
    },
    "dependencies": {
        "electron-updater": "^6.8.9",
        "express": "^5.2.1",
        "http-proxy-middleware": "^4.2.0",
        "leaflet": "^1.9.4",
        "react-leaflet": "^5.0.0",
        "xlsx-js-style": "^1.2.0"
    },
    "devDependencies": {
        "@headlessui/react": "^2.2.0",
        "@playwright/test": "^1.61.1",
        "@radix-ui/react-accordion": "^1.2.12",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-avatar": "^1.1.3",
        "@radix-ui/react-checkbox": "^1.1.4",
        "@radix-ui/react-collapsible": "^1.1.3",
        "@radix-ui/react-dialog": "^1.1.6",
        "@radix-ui/react-dropdown-menu": "^2.1.6",
        "@radix-ui/react-label": "^2.1.2",
        "@radix-ui/react-navigation-menu": "^1.2.5",
        "@radix-ui/react-progress": "^1.1.8",
        "@radix-ui/react-select": "^2.1.6",
        "@radix-ui/react-separator": "^1.1.2",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@radix-ui/react-toggle": "^1.1.2",
        "@radix-ui/react-toggle-group": "^1.1.2",
        "@radix-ui/react-tooltip": "^1.1.8",
        "@tailwindcss/vite": "^4.3.2",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@types/dompurify": "^3.0.5",
        "@types/leaflet": "^1.9.21",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-basic-ssl": "^2.3.0",
        "@vitejs/plugin-react": "^5.0.0",
        "@vitest/coverage-v8": "^3.2.4",
        "@vladmandic/face-api": "^1.7.15",
        "@vvo/tzdb": "^6.198.0",
        "axios": "^1.7.9",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "concurrently": "^10.0.3",
        "dompurify": "^3.4.8",
        "electron": "^42.3.2",
        "electron-builder": "^26.8.1",
        "embla-carousel-react": "^8.6.0",
        "i18n-iso-countries": "^7.14.0",
        "input-otp": "^1.4.2",
        "jsdom": "^26.1.0",
        "lucide-react": "^0.475.0",
        "mammoth": "^1.12.0",
        "msw": "^2.14.6",
        "playwright": "^1.49.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-hot-toast": "^2.6.0",
        "react-router-dom": "^7.6.2",
        "recharts": "^2.15.4",
        "sharp": "^0.34.5",
        "tailwind-merge": "^3.0.1",
        "tailwindcss": "^4.0.0",
        "to-ico": "^1.1.5",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5.7.2",
        "vite": "^7.0.4",
        "vite-plugin-pwa": "^1.3.0",
        "vitest": "^3.2.4",
        "wait-on": "^9.0.10",
        "xlsx": "^0.18.5"
    }
}
