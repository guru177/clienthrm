# Backend API root used by the Vite dev proxy (and optional production override).
# The dev server proxies /api → this origin.
VITE_API_URL=http://127.0.0.1:3001/api

# Optional explicit proxy target (origin only, no /api suffix).
# VITE_DEV_API_TARGET=http://127.0.0.1:3001

# Tenant HRM app URL (impersonation redirects).
VITE_TENANT_APP_URL=http://localhost:5174
